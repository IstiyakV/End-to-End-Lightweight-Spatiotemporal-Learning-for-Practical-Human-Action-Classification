<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05030d"
    tools:context=".RealTimeCameraActivity">

    <!-- Viewfinder Background Placeholder / Simulated Live Tracker -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Real camera preview -->
        <TextureView
            android:id="@+id/cameraTextureView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Simulated live video feed background (shown when camera texture is loading) -->
        <ImageView
            android:id="@+id/simulatedCameraBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/bg_chat_bubble_ai"
            android:scaleType="centerCrop"
            android:alpha="0.2"
            android:visibility="visible"/>

        <!-- HUD Scanline Grid Overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_chat_bubble_ai"
            android:alpha="0.05"
            android:layout_margin="10dp"/>

        <!-- Holographic Vector Skeleton Outline Mockup -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center">

            <!-- Glowing tracking skeleton circle target -->
            <ImageView
                android:layout_width="220dp"
                android:layout_height="320dp"
                android:src="@drawable/bg_chat_bubble_ai"
                android:backgroundTint="#a855f7"
                android:alpha="0.25"/>

            <!-- Laser scanning line -->
            <View
                android:layout_width="240dp"
                android:layout_height="2dp"
                android:background="#a855f7"
                android:layout_marginTop="160dp"
                android:alpha="0.8"/>
        </RelativeLayout>
    </FrameLayout>

    <!-- Overlay HUD UI Layer -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top Status Bar HUD Overlay -->
        <RelativeLayout
            android:id="@+id/cameraHudHeader"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp"
            android:background="#b005030d">

            <!-- Sleek Back/Close Button -->
            <ImageButton
                android:id="@+id/btnBackHeader"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="Exit"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvCameraTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toRightOf="@id/btnBackHeader"
                android:layout_marginLeft="8dp"
                android:text="LUMAT EDGE HAR"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"/>

            <!-- Pulsating live recording badge -->
            <LinearLayout
                android:id="@+id/liveTrackingBadgeLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_chat_bubble_user"
                    android:backgroundTint="#FF3B30"
                    android:layout_marginRight="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVE"
                    android:textColor="#FF3B30"
                    android:textSize="10sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Switch Camera Button (CAM) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSwitchCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:layout_toLeftOf="@id/liveTrackingBadgeLayout"
                android:layout_centerVertical="true"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="#00FF66"
                android:textSize="10sp"
                android:text="CAM"
                app:icon="@android:drawable/ic_menu_camera"
                app:iconTint="#00FF66"
                app:iconSize="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"/>

            <!-- Switch Offline Model Button (MODEL) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangeModel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:layout_toLeftOf="@id/btnSwitchCamera"
                android:layout_centerVertical="true"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="#a855f7"
                android:textSize="10sp"
                android:text="MODEL"
                app:icon="@android:drawable/ic_menu_manage"
                app:iconTint="#a855f7"
                app:iconSize="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"/>

        </RelativeLayout>

        <!-- Floating Glassmorphic Classification Dashboard Overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentBottom="true"
            android:padding="20dp"
            android:background="#e50b071a"
            android:layout_margin="16dp"
            android:elevation="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOCAL INFERENCE EDGE CLASSIFIER"
                android:textColor="#8b82a0"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <!-- Active Model Name Label -->
            <TextView
                android:id="@+id/tvActiveModelLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Model: ucf101_run_best.ptl"
                android:textColor="#8b82a0"
                android:textSize="11sp"
                android:layout_marginBottom="8dp"/>

            <!-- Status Indicator Row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_chat_bubble_user"
                    android:backgroundTint="#00FF66"
                    android:layout_marginRight="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skeletal Joints Map OK - Latency: 4ms - 32 FPS"
                    android:textColor="#00FF66"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Predicted Class Dynamic Label -->
            <TextView
                android:id="@+id/liveActionClass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Detected Action: Standing..."
                android:textColor="#a855f7"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <!-- Live confidence visual scale -->
            <ProgressBar
                android:id="@+id/liveActionProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressDrawable="@drawable/progress_bar_neon"
                android:max="100"
                android:progress="78"
                android:layout_marginBottom="20dp"/>

            <!-- Exit camera mode button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStopCamera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                app:backgroundTint="#1a103c"
                app:strokeColor="#FF3B30"
                app:strokeWidth="1dp"
                app:cornerRadius="5dp"
                android:text="STOP REAL-TIME HUD SESSION"
                android:textColor="#FF3B30"/>
        </LinearLayout>
    </RelativeLayout>

</FrameLayout>
