<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_chat_bubble_ai">

    <!-- Card Title -->
    <TextView
        android:id="@+id/metricsCardTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Plain-3DCNN Metrics"
        android:textColor="#a855f7"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Global Stats Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp"
        android:weightSum="2">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp"
            android:background="#25154f">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accuracy"
                android:textColor="#8b82a0"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/metricsAccuracyValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="54.5%"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <View
            android:layout_width="8dp"
            android:layout_height="1dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp"
            android:background="#25154f">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Macro F1"
                android:textColor="#8b82a0"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/metricsF1Value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.537"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Top 10 Classes by F1-Score"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="12sp"
        android:layout_marginBottom="6dp"/>

    <!-- Dynamic rows container -->
    <LinearLayout
        android:id="@+id/metricsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <!-- Dyn list items inserted here -->
    </LinearLayout>

</LinearLayout>
