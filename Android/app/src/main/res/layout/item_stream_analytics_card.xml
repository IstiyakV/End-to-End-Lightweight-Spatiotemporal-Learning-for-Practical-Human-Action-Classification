<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_chat_bubble_ai">

    <!-- Section Heading -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PREDICTION ANALYSIS &amp; VISUALISATION"
        android:textColor="#8b82a0"
        android:textSize="10sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <!-- Dynamic Prediction Details -->
    <TextView
        android:id="@+id/streamResultClass"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="IceDancing"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp"/>

    <TextView
        android:id="@+id/streamResultConfidence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confidence: 52.5%"
        android:textColor="#00FF66"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp"/>

    <TextView
        android:id="@+id/streamResultLatency"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Latency: 20 ms"
        android:textColor="#8b82a0"
        android:textSize="11sp"
        android:layout_marginBottom="14dp"/>

    <!-- Class Probabilities Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Class Probabilities (Top-5)"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Container for Top-5 Probability Bars -->
    <LinearLayout
        android:id="@+id/probsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">
        <!-- Dyn list items inserted here -->
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1a103c"
        android:layout_marginBottom="14dp"/>

    <!-- Stream Analytics Heading -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 Stream Session Analytics"
        android:textColor="#a855f7"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chronological Activity Timeline"
        android:textColor="#8b82a0"
        android:textSize="10sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"/>

    <!-- Timeline Color-Segment Bar Container -->
    <LinearLayout
        android:id="@+id/timelineContainer"
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:orientation="horizontal"
        android:background="#1a103c"
        android:layout_marginBottom="16dp">
        <!-- Added dynamically in Java -->
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Session Primary Action Share (Cumulative)"
        android:textColor="#8b82a0"
        android:textSize="10sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Container for Share Percentages -->
    <LinearLayout
        android:id="@+id/cumulativeShareContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">
        <!-- Dyn share progress rows inserted here -->
    </LinearLayout>

    <!-- Blinking Streaming Status Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#0b071a"
        android:padding="8dp">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_chat_bubble_user"
            android:backgroundTint="#00FF66"
            android:layout_marginRight="6dp"/>

        <TextView
            android:id="@+id/streamFpsFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Streaming live... Processing: 21 FPS"
            android:textColor="#00FF66"
            android:textSize="10sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
